{
    "name": "ljadrbln/php-dependency-extractor",
    "description": "Extract reachable PHP project files by analyzing dependencies from one or more entry points.",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": "^8.3"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.5",
        "phpstan/phpstan": "^2.1"
    },
    "autoload": {
        "psr-4": {
            "PhpDependencyExtractor\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "PhpDependencyExtractor\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "stan": "phpstan analyse src tests"
    }
}